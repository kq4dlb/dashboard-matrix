{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dashboard-matrix.example/schemas/layout.schema.json",
  "title": "Dashboard Matrix Layout",
  "type": "object",
  "required": ["schema_version", "export_type", "dashboards"],
  "properties": {
    "schema_version": {"const": 1},
    "export_type": {"const": "dashboard-matrix-layout"},
    "generated_at": {"type": "string"},
    "dashboard_matrix_version": {"type": "string"},
    "author": {"type": "object"},
    "metadata": {
      "type": "object",
      "properties": {
        "title": {"type": "string", "maxLength": 120},
        "description": {"type": "string", "maxLength": 2000},
        "tags": {"type": "array", "items": {"type": "string"}, "maxItems": 20}
      },
      "additionalProperties": true
    },
    "dashboards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "slug", "columns", "rows", "tiles"],
        "properties": {
          "name": {"type": "string"},
          "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "columns": {"type": "integer", "minimum": 1, "maximum": 12},
          "rows": {"type": "integer", "minimum": 1, "maximum": 24},
          "tiles": {"type": "array", "items": {"type": "object"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
